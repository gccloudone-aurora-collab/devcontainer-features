{
  "image": "mcr.microsoft.com/devcontainers/javascript-node:4-20-bookworm",
  "customizations": {
    "vscode": {
      "settings": {
        "json.schemas": [
          {
            "fileMatch": ["*/devcontainer-feature.json"],
            "url": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainerFeature.schema.json"
          }
        ]
      },
      "extensions": ["mads-hartmann.bash-ide-vscode"]
    }
  },
  "overrideFeatureInstallOrder": ["ghcr.io/KingBain/devcontainer-features/cert-update"],
  "features": {
    "ghcr.io/KingBain/devcontainer-features/cert-update:1": {
      "required": false
    },
    "ghcr.io/devcontainers/features/docker-in-docker:3": {},
    "ghcr.io/devcontainers-community/npm-features/prettier:1": {},
    "ghcr.io/devcontainers/features/python:1": {}
  },
  "remoteUser": "node",
  "updateContentCommand": "npm install -g @devcontainers/cli"
}
